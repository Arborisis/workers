# Configuration du Worker Arborisis

# ===============================
# REQUIS
# ===============================

# Token d'authentification (récupéré depuis le dashboard)
WORKER_TOKEN=your-worker-token-here

# URL de l'API Arborisis
API_URL=https://arborisis.com

# ===============================
# R2 STORAGE (Cloudflare)
# ===============================

# Endpoint R2 (format: https://<account-id>.r2.cloudflarestorage.com)
R2_ENDPOINT=https://xxx.r2.cloudflarestorage.com

# Credentials R2
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key

# Nom du bucket
R2_BUCKET_NAME=arborisis-audio

# ===============================
# OPTIONNEL
# ===============================

# Nom du worker (affiché dans le dashboard)
WORKER_NAME=My Audio Worker

# Port local pour le healthcheck
WORKER_PORT=8080

# Limites mémoire (pour Docker)
MEMORY_LIMIT=4G
MEMORY_RESERVATION=1G

# Debug mode
DEBUG=false

# Intervalle heartbeat (secondes)
HEARTBEAT_INTERVAL=30

# Timeout de traitement (secondes)
PROCESSING_TIMEOUT=1800