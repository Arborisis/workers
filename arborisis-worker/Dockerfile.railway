# Arborisis Worker - Version Railway (CPU-only, allégée)
FROM python:3.11-slim-bookworm

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV PIP_DEFAULT_TIMEOUT=300

# Dépendances système
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    cmake \
    git \
    curl \
    wget \
    ffmpeg \
    libsndfile1 \
    libgomp1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copier requirements
COPY requirements.txt .
RUN pip install --no-cache-dir --prefer-binary -r requirements.txt

# BirdNET (optionnel, lourd)
# RUN git clone --depth 1 https://github.com/kahst/BirdNET-Analyzer.git /opt/birdnet && \
#     pip install --no-cache-dir -e /opt/birdnet

# Copier le code
COPY *.py ./

# Répertoire modèles
RUN mkdir -p /models
ENV MODELS_DIR=/models

# Pas de téléchargement automatique des modèles LLM (trop lourd pour Railway)
# Les modèles audio (BirdNET) sont utilisés directement

# Healthcheck
HEALTHCHECK --interval=60s --timeout=10s --start-period=30s --retries=3 \
  CMD python3 -c "import requests; requests.get('http://localhost:8080/health')" || exit 1

EXPOSE 8080

CMD ["python3", "worker.py"]
